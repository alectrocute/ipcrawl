# ipcrawl VPS runtime environment.
#
# Copy to /srv/ipcrawl/env on the server (root-owned, chmod 600) and fill in the
# secrets. systemd loads this via EnvironmentFile (see ipcrawl.service). These
# replace the wrangler.jsonc `vars` block plus the Worker secrets.

# --- Runtime wiring (VPS-specific) ------------------------------------------
# Selects the fs storage drivers + node:sqlite path in nuxt.config.ts /
# exploreDb.ts. Must stay node-server on the VPS.
NITRO_PRESET=node-server
# Nitro listens here; nginx proxies to it. 127.0.0.1 keeps the app off the
# public interface (only nginx and, transitively, Cloudflare can reach it).
NITRO_HOST=127.0.0.1
NITRO_PORT=3000
# Persistent data volume. screenshots (was R2), cams KV log (was KV), and the
# SWR cache live under here; the SQLite file is set explicitly below.
NUXT_DATA_DIR=/srv/ipcrawl/data
NUXT_SQLITE_PATH=/srv/ipcrawl/data/explore.sqlite

# --- Secrets (were `wrangler secret put`) -----------------------------------
NUXT_SHODAN_API_KEY=your-shodan-api-key
NUXT_VOTER_PEPPER=your-voter-pepper
NUXT_CAM_ID_PEPPER=your-cam-id-pepper

# --- Public config (were wrangler `vars`) -----------------------------------
NUXT_PUBLIC_SITE_URL=https://ipcrawl.com
NUXT_PUBLIC_IMCE_DOMAIN=ismycameraexposed.com
NUXT_PUBLIC_FEATURED_CAM_ID=
NUXT_SHODAN_LIMIT_PER_QUERY=2999
NUXT_SHODAN_REFRESH_ON_BOOT=false

# --- Feature flags / ops brakes (were wrangler `vars`) ----------------------
# Emergency kill switch: serve only cached screenshots, skip live probes.
NUXT_EDGE_KILL_SWITCH=false
# Overload brake: redirect HTML to /offline-for-now and 503 the API.
NUXT_OFFLINE_FOR_NOW=false
# Live camera probing (uses Node fetch on the VPS — no cloudflare:sockets).
NUXT_ENABLE_LIVE_PROBE=true
# Keep fallback screenshots fresh from successful live frames.
NUXT_ENABLE_LIVE_FRAME_PERSIST=true
